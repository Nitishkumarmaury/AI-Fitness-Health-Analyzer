{
    "family": "ai-fitness-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "ai-fitness-container",
            "image": "739275445721.dkr.ecr.us-east-1.amazonaws.com/ai-fitness-analyzer:latest",
            "portMappings": [
                {
                    "containerPort": 8501,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "GEMINI_API_KEY",
                    "value": "AIzaSyCmCit_f6F6EBC6yEIeith1apjJ8AH3rWY"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/ai-fitness-analyzer",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "essential": true
        }
    ]
}